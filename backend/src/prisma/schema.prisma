// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "mysql"
}

enum AddressType {
  BILLING
  SHIPPING
  PERMANENT_ADDRESS
}

enum PaymentType {
  NATIONAL
  INTERNATIONAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PaymentMethod {
  QR
  PAY_AT_VENUE
}

enum RunnerStatus {
  DID_NOT_FINISH
  DISQUALIFIED
  ACTIVE
}

model Address {
  id      String @id @default(cuid())
  street  String
  address String
  city    String
  state   String
  zipCode String

  country_id String
  country    Country     @relation(fields: [country_id], references: [id], onDelete: Cascade)
  type       AddressType

  companies Company[]
  orders    Order[]

  @@map("addresses")
}

model AgeCategory {
  id         String    @id @default(cuid())
  name       String
  created_at DateTime  @default(now())
  updated_at DateTime?
  deleted_at DateTime?

  personal Personal[]

  @@map("age_categories")
}

model Checkpoint {
  id          String    @id @default(cuid())
  name        String
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?
  is_start    Boolean   @default(false)
  is_end      Boolean   @default(false)

  stage_category_id String
  stage_category    StageCategory @relation(fields: [stage_category_id], references: [id], onDelete: Cascade)

  runners                  EventRunner[]
  volunteers               Volunteer[]
  volunteer_on_checkpoints VolunteerCheckpoint[]

  @@map("checkpoints")
}

model Country {
  id         String    @id @default(cuid())
  name       String    @db.VarChar(255)
  abbr       String    @unique
  code       String    @db.VarChar(255)
  created_at DateTime  @default(now())
  updated_at DateTime?

  personal  Personal[]
  addresses Address[]

  @@map("countries")
}

model Company {
  id             String   @id @default(cuid())
  name           String
  short_name     String
  email          String
  address_id     String?
  address        Address? @relation(fields: [address_id], references: [id], onDelete: Cascade)
  phone          String
  vat_registered Boolean
  pan_no         String?
  vat_no         String?
  image_id       String?
  logo           Image?   @relation(fields: [image_id], references: [id], onDelete: Cascade)

  users        User[]
  social_links SocialLink[]

  @@map("companies")
}

model Club {
  id          String    @id @default(cuid())
  name        String
  description String
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  @@map("clubs")
}

model EventRunner {
  id                     String    @id @default(cuid())
  bib                    String
  created_at             DateTime  @default(now())
  updated_at             DateTime?
  deleted_at             DateTime?
  club_name              String    @default("")
  emergency_contact_name String    @default("")
  emergency_contact_no   String    @default("")
  want_lunch             Boolean   @default(false)

  personal_id       String
  personal          Personal      @relation(fields: [personal_id], references: [id], onDelete: Cascade)
  event_id          String
  event             TrailRace     @relation(fields: [event_id], references: [id], onDelete: Cascade)
  stage_category_id String
  stage_category    StageCategory @relation(fields: [stage_category_id], references: [id], onDelete: Cascade)
  stage_id          String
  stage             Stage         @relation(fields: [stage_id], references: [id], onDelete: Cascade)
  shirt_id          String?
  tshirt_size       Size?         @relation(fields: [shirt_id], references: [id], onDelete: Cascade)

  checkpoints              Checkpoint[]
  payments                 Payment[]
  volunteer_on_checkpoints VolunteerCheckpoint[]
  status                   EventRunnerStatus?
  rank                     Rank?
  runner_attendances       RunnerAttendance[]

  @@unique([bib, stage_category_id])
  @@map("event_runners")
}

model Gender {
  id   String @id @default(cuid())
  name String

  personal Personal[]
  ranks    Rank[]

  @@map("genders")
}

model Image {
  id          String    @id @default(cuid())
  file_name   String
  description String
  created_at  DateTime  @default(now())
  updated_at  DateTime?

  personal                Personal[]
  events                  TrailRace[]            @relation("thumbnail_image")
  maps                    TrailRace[]            @relation("map_image")
  companies               Company[]
  gallery_event           TrailRace[]            @relation("trail_race_gallery")
  thumbnail_stages        Stage[]                @relation("thumbnail_image")
  payments                Payment[]
  stage_categories        StageCategory[]        @relation("gpx_file")
  sponsort_types          SponsorType[]
  sponsors                Sponsor[]
  stage_category_payments StageCategoryPayment[]
  // stage_category_bibs     StageCategory[]        @relation("stage_category_bib")
  tags                    Tag[]
  gallery                 Gallery?               @relation(fields: [galleryId], references: [id])
  galleryId               String?
  treks                   Trek[]
  product_thumbnails      Product[]              @relation("product_thumbnail")

  @@map("images")
}

model Newsletter {
  id            String    @id @default(cuid())
  email         String    @unique
  subscribed_at DateTime  @default(now())
  deleted_at    DateTime?

  user_id String?
  user    Personal? @relation(fields: [user_id], references: [id])

  @@map("newsletters")
}

model Permission {
  id          String    @id @default(cuid())
  name        String
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  roles Role[]

  @@map("permissions")
}

model Partner {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  events TrailRace[]

  @@map("partners")
}

model PartnerCategory {
  id          String    @id @default(cuid())
  name        String
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  @@map("partner_categories")
}

model Personal {
  id            String    @id @default(cuid())
  first_name    String?
  middle_name   String?
  last_name     String?
  email         String    @unique
  date_of_birth DateTime?
  phone_number  String?
  created_at    DateTime  @default(now())
  updated_at    DateTime?
  deleted_at    DateTime?

  country_id      String?
  country         Country?     @relation(fields: [country_id], references: [id], onDelete: Cascade)
  age_category_id String?
  age_category    AgeCategory? @relation(fields: [age_category_id], references: [id], onDelete: Cascade)
  size_id         String?
  size            Size?        @relation(fields: [size_id], references: [id], onDelete: Cascade)
  image_id        String?
  avatar          Image?       @relation(fields: [image_id], references: [id], onDelete: Cascade)
  gender_id       String?
  gender          Gender?      @relation(fields: [gender_id], references: [id])

  users       User[]
  volunteers  Volunteer[]
  runners     EventRunner[]
  newsletters Newsletter[]

  @@map("personals")
}

model Payment {
  id         String        @id @default(cuid())
  amount     Decimal
  method     PaymentMethod
  status     PaymentStatus @default(PENDING)
  created_at DateTime      @default(now())
  updated_at DateTime?
  deleted_at DateTime?

  stage_category_id String
  stage_category    StageCategory? @relation(fields: [stage_category_id], references: [id])
  runner_id         String
  runner            EventRunner?   @relation(fields: [runner_id], references: [id])
  image_id          String?
  screenshot        Image?         @relation(fields: [image_id], references: [id])

  @@map("payments")
}

model Role {
  id          String    @id @default(cuid())
  name        String
  description String?
  publish     Boolean?
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  permissions Permission[]
  users       User[]

  @@map("roles")
}

model Size {
  id          String    @id @default(cuid())
  name        String
  description String
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  Personal         Personal[]
  runners          EventRunner[]
  product_variants ProductVariant[]

  @@map("sizes")
}

model Sponsor {
  id          String    @id @default(cuid())
  name        String
  description String?
  url         String?
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  race_id       String?
  race          TrailRace?   @relation(fields: [race_id], references: [id], onDelete: Cascade)
  sponsorType   SponsorType? @relation(fields: [sponsorTypeId], references: [id])
  sponsorTypeId String?
  thumbnail_id  String?
  thumbnail     Image?       @relation(fields: [thumbnail_id], references: [id])

  social_links SocialLink[]

  @@map("sponsors")
}

model SponsorType {
  id          String    @id @default(cuid())
  name        String
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  sponsors Sponsor[]
  image    Image?    @relation(fields: [imageId], references: [id])
  imageId  String?

  @@map("sponsor_types")
}

model Stage {
  id          String    @id @default(cuid())
  name        String
  excerpt     String    @db.Text
  description String    @db.LongText
  location    String
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  event_id  String
  event     TrailRace @relation(fields: [event_id], references: [id], onDelete: Cascade)
  image_id  String?
  thumbnail Image?    @relation("thumbnail_image", fields: [image_id], references: [id], onDelete: Cascade)

  runners            EventRunner[]
  volunteers         Volunteer[]
  stage_categories   StageCategory[]
  runner_attendances RunnerAttendance[]

  @@map("stages")
}

model StageCategory {
  id          String    @id @default(cuid())
  name        String
  excerpt     String
  description String    @db.Text
  distance    String?
  difficulty  String?
  location    String
  start       DateTime?
  end         DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?
  bib_range   String    @default("0-0")

  stage_id    String
  stage       Stage   @relation(fields: [stage_id], references: [id], onDelete: Cascade)
  map_file_id String?
  map_file    Image?  @relation("gpx_file", fields: [map_file_id], references: [id], onDelete: Cascade)
  /**
   * image_id    String?
   * bib_image   Image?  @relation("stage_category_bib", fields: [image_id], references: [id], onDelete: Cascade)
   */

  checkpoints Checkpoint[]
  runners     EventRunner[]
  payment     StageCategoryPayment[]
  payments    Payment[]
  ranks       Rank[]

  @@map("stage_categories")
}

model TrailRace {
  id          String    @id @default(cuid())
  name        String
  slug        String?
  start       DateTime
  end         DateTime
  excerpt     String?   @db.Text
  description String    @db.LongText
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  image_id    String?
  thumbnail   Image?  @relation("thumbnail_image", fields: [image_id], references: [id], onDelete: Cascade)
  map_file_id String?
  map_file    Image?  @relation("map_image", fields: [map_file_id], references: [id], onDelete: Cascade)

  stages    Stage[]
  runners   EventRunner[]
  galleries Image[]       @relation("trail_race_gallery")
  partners  Partner[]
  sponsors  Sponsor[]
  tags      Tag[]

  @@map("events")
}

model StageCategoryPayment {
  id          String      @id @default(cuid())
  amount      Decimal
  created_at  DateTime    @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?
  type        PaymentType
  description String?

  stage_category_id String
  stage_category    StageCategory @relation(fields: [stage_category_id], references: [id], onDelete: Cascade)
  image_id          String
  screenshot        Image         @relation(fields: [image_id], references: [id], onDelete: Cascade)

  @@map("stage_category_payments")
}

model User {
  id         String    @id @default(cuid())
  password   String
  created_at DateTime  @default(now())
  updated_at DateTime?
  deleted_at DateTime?

  personal_id     String          @unique
  personal        Personal        @relation(fields: [personal_id], references: [id], onDelete: Cascade)
  role_id         String?
  role            Role?           @relation(fields: [role_id], references: [id], onDelete: Cascade)
  Company         Company?        @relation(fields: [companyId], references: [id])
  companyId       String?
  product_reviews ProductReview[]
  orders          Order[]

  @@map("users")
}

model Volunteer {
  id          String    @id @default(cuid())
  description String    @db.Text
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  personal_id String
  personal    Personal @relation(fields: [personal_id], references: [id], onDelete: Cascade)

  stages      Stage[]
  checkpoints Checkpoint[]

  volunteer_on_checkpoints VolunteerCheckpoint[]

  @@map("volunteers")
}

model VolunteerCheckpoint {
  id            String      @id @default(cuid())
  timer         DateTime    @default(now())
  volunteer_id  String
  volunteer     Volunteer   @relation(fields: [volunteer_id], references: [id], onDelete: Cascade)
  runner_id     String
  runner        EventRunner @relation(fields: [runner_id], references: [id], onDelete: Cascade)
  checkpoint_id String
  checkpoint    Checkpoint  @relation(fields: [checkpoint_id], references: [id], onDelete: Cascade)
  created_at    DateTime    @default(now())

  @@map("volunteer_on_checkpoints")
}

model EventRunnerStatus {
  id         String       @id @default(cuid())
  status     RunnerStatus @default(ACTIVE)
  runner_id  String       @unique
  runner     EventRunner  @relation(fields: [runner_id], references: [id], onDelete: Cascade)
  created_at DateTime     @default(now())

  @@map("event_runner_status")
}

model Rank {
  id                String        @id @default(cuid())
  position          Int
  runner_id         String        @unique
  runner            EventRunner   @relation(fields: [runner_id], references: [id], onDelete: Cascade)
  stage_category_id String
  stage_category    StageCategory @relation(fields: [stage_category_id], references: [id], onDelete: Cascade)
  gender_id         String?
  gender            Gender?       @relation(fields: [gender_id], references: [id], onDelete: Cascade)
  created_at        DateTime      @default(now())

  @@unique([position, stage_category_id, gender_id])
  @@map("ranks")
}

model RunnerAttendance {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())

  runner_id String
  runner    EventRunner @relation(fields: [runner_id], references: [id], onDelete: Cascade)

  stage_id String
  stage    Stage  @relation(fields: [stage_id], references: [id], onDelete: Cascade)

  @@unique([runner_id, stage_id])
  @@map("runner_attendance")
}

model Tag {
  id         String      @id @default(cuid())
  name       String
  created_at DateTime    @default(now())
  updated_at DateTime?
  deleted_at DateTime?
  events     TrailRace[]
  images     Image[]
  galleries  Gallery[]
  treks      Trek[]
  products   Product[]

  @@map("tags")
}

model Gallery {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  images   Image[]
  tags     Tag[]
  treks    Trek[]
  products Product[] @relation("product_gallery")

  @@map("galleries")
}

model SocialLink {
  id         String    @id @default(cuid())
  name       String
  url        String
  created_at DateTime  @default(now())
  updated_at DateTime?
  deleted_at DateTime?

  company  Company[]
  sponsors Sponsor[]

  @@map("social_links")
}

model Trek {
  id           String    @id @default(cuid())
  name         String
  slug         String?   @unique
  excerpt      String?
  description  String?   @db.Text
  price        String
  /// TrekDetail
  details      Json?
  published_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime?
  deleted_at   DateTime?

  image_id   String?
  thumbnail  Image?   @relation(fields: [image_id], references: [id], onDelete: Cascade)
  gallery_id String?
  gallery    Gallery? @relation(fields: [gallery_id], references: [id], onDelete: Cascade)

  category_id String?
  category    TrekCategory? @relation(fields: [category_id], references: [id])

  tags     Tag[]
  bookings TrekBooking[]

  @@map("treks")
}

model TrekCategory {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  treks Trek[]

  @@map("trek_categories")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model TrekBooking {
  id             String        @id @default(cuid())
  status         BookingStatus @default(PENDING)
  departure_date DateTime
  adults         Int           @default(1)
  children       Int           @default(0)
  gear_option    String        @default("standard") // "standard" | "pro"
  insurance      Boolean       @default(true)
  airport_pickup Boolean       @default(false)
  subtotal       Decimal       @db.Decimal(10, 2)
  total_price    Decimal       @db.Decimal(10, 2)
  notes          String?       @db.Text
  created_at     DateTime      @default(now())
  updated_at     DateTime?
  deleted_at     DateTime?

  // Lead traveler denormalized for quick access
  lead_name          String
  lead_passport      String
  lead_fitness_level String
  lead_altitude_exp  String?
  lead_dietary       String?

  trek_id String
  trek    Trek   @relation(fields: [trek_id], references: [id], onDelete: Cascade)

  travelers TrekBookingTraveler[]

  @@map("trek_bookings")
}

model TrekBookingTraveler {
  id          String   @id @default(cuid())
  name        String
  passport    String
  nationality String?
  age         Int?
  dietary     String?
  is_lead     Boolean  @default(false)
  created_at  DateTime @default(now())

  booking_id String
  booking    TrekBooking @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@map("trek_booking_travelers")
}

// Added enums and model for store settings

enum ShippingCalculationMethod {
  PRICE_BASED
  PACKAGE_LIBRARY
}

model StoreSetting {
  id                          String                    @id @default(cuid())
  currency                    String                    @default("USD")
  unit_of_measurement         String                    @default("metric")
  timezone                    String                    @default("UTC")
  shipping_zones              Json?
  shipping_packages           Json?
  shipping_calculation_method ShippingCalculationMethod @default(PRICE_BASED)
  free_shipping_threshold     Float?                    @default(0)
  tax_inclusion               Boolean                   @default(false)
  tax_apply_to_shipping       Boolean                   @default(false)
  nexus_regions               Json?
  guest_checkout              Boolean                   @default(true)
  abandoned_cart_recovery     Boolean                   @default(false)
  abandoned_cart_delay        Int                       @default(60)
  policy_pages                Json?
  oversell_protection         Boolean                   @default(false)
  allow_backorder             Boolean                   @default(false)
  low_stock_threshold         Int                       @default(5)
  order_id_prefix             String?                   @default("ORD-")
  created_at                  DateTime                  @default(now())
  updated_at                  DateTime?

  @@map("store_settings")
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  deleted_at  DateTime?

  parent_id String?
  parent    ProductCategory?  @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children  ProductCategory[] @relation("CategoryHierarchy")

  products Product[]

  @@map("product_categories")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  badge          String? // e.g., "Bestseller", "New"
  excerpt        String?  @db.Text
  description    String   @db.LongText
  published_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime?
  deleted_at   DateTime?

  category_id String
  category    ProductCategory @relation(fields: [category_id], references: [id])

  thumbnail_id String?
  thumbnail    Image?   @relation("product_thumbnail", fields: [thumbnail_id], references: [id])
  gallery_id   String?
  gallery      Gallery? @relation("product_gallery", fields: [gallery_id], references: [id])

  variants    ProductVariant[]
  specs       ProductSpec[]
  reviews     ProductReview[]
  order_items OrderItem[]
  tags        Tag[]

  @@map("products")
}

model ProductVariant {
  id    String   @id @default(cuid())
  sku   String   @unique
  price          Decimal  @db.Decimal(10, 2)
  original_price Decimal? @db.Decimal(10, 2) // For promotions / strike-through pricing
  stock             Int      @default(0)
  sold              Int      @default(0)
  returned          Int      @default(0)
  restock_threshold Int      @default(5)

  product_id String
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  size_id String?
  size    Size?   @relation(fields: [size_id], references: [id])

  order_items OrderItem[]

  @@map("product_variants")
}

model ProductSpec {
  id    String @id @default(cuid())
  label String // e.g., "Weight", "Waterproof Rating"
  value String // e.g., "850g", "20,000mm"

  product_id String
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_specs")
}

model ProductReview {
  id      String  @id @default(cuid())
  rating  Float // e.g., 4.5
  title   String?
  content String  @db.Text

  author_name String? // If guest review
  author_role String? // e.g., "Pro Alpinist"

  created_at DateTime  @default(now())
  updated_at DateTime?

  product_id String
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@map("product_reviews")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  discount_type  DiscountType
  discount_value Decimal      @db.Decimal(10, 2)
  valid_from     DateTime?
  valid_until    DateTime?
  usage_limit    Int? // Max times this coupon can be used
  times_used     Int          @default(0)
  is_active      Boolean      @default(true)

  created_at DateTime  @default(now())
  updated_at DateTime?

  orders Order[]

  @@map("coupons")
}

// ==========================================
// ORDER MODELS (To support checkout)
// ==========================================

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id           String      @id @default(cuid())
  order_number String      @unique
  status       OrderStatus @default(PENDING)
  email        String?
  phone        String?

  subtotal       Decimal @db.Decimal(10, 2)
  tax            Decimal @db.Decimal(10, 2)
  shipping_fee   Decimal @db.Decimal(10, 2)
  discount_total Decimal @default(0) @db.Decimal(10, 2)
  total          Decimal @db.Decimal(10, 2)

  created_at DateTime  @default(now())
  updated_at DateTime?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  coupon_id String?
  coupon    Coupon? @relation(fields: [coupon_id], references: [id])

  items OrderItem[]

  // Relation to existing Address table for shipping
  shipping_address_id String
  shipping_address    Address @relation(fields: [shipping_address_id], references: [id])

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(cuid())
  quantity   Int
  unit_price Decimal @db.Decimal(10, 2)

  order_id String
  order    Order  @relation(fields: [order_id], references: [id], onDelete: Cascade)

  product_id String
  product    Product @relation(fields: [product_id], references: [id])

  variant_id String?
  variant    ProductVariant? @relation(fields: [variant_id], references: [id])

  @@map("order_items")
}
